{
	"format_version": "1.8.0",
	"animations": {
		"animation.car.move": {
			"loop": true,
			"override_previous_animation": true,
			"bones": {
				"leftFrontWheel": {
					"rotation": ["q.anim_time * v.wheel_speed", "v.wheel_rotation", 0]
				},
				"rightFrontWheel": {
					"rotation": ["q.anim_time * v.wheel_speed", "v.wheel_rotation", 0]
				},
				"steeringWheel": {
					"rotation": [0, 0, "-(v.wheel_rotation * 5)"]
				},
				"root": {
					"rotation": ["math.clamp(-query.body_x_rotation, -45, 45)", 0, 0],
					"position": [0, "math.clamp(query.body_x_rotation / 45, -1, 1) * 16", 0]
				},
				"leftBackWheel": {
					"rotation": ["q.anim_time * v.wheel_speed", 0, 0]
				},
				"rightBackWheel": {
					"rotation": ["q.anim_time * v.wheel_speed", 0, 0]
				}
			}
		}
	}
}