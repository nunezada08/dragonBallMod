{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.flying_nimbus.general": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"flying_nimbus": "q.variant == 0"
						},
						{
							"black_flying_nimbus": "q.variant == 1"
						}
					]
				},
				"flying_nimbus": {
					"animations": [ "flying" ],
					"particle_effects": [
						{
							"effect": "flying_nimbus",
							"locator": "root"
						}
					]
				},
				"black_flying_nimbus": {
					"animations": [ "flying" ],
					"particle_effects": [
						{
							"effect": "flying_nimbus",
							"pre_effect_script": "v.r = 0.06666; v.g = 0.05098; v.b = 0.12941;"
						}
					]
				}
			}
		}
	}
}