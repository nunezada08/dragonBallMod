{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.player.makankosappo": {
			"states": {
				"default": {
					"blend_transition": 0.2,
					"transitions": [
						{
							"makankosappo": "v.charging_attack == 5"
						}
					]
				},
				"makankosappo": {
					"animations": [
						"ki_attack_setup",
						{
							"first_person_makankosappo": "v.is_first_person"
						},
						{
							"makankosappo": "!v.is_first_person"
						}
					],
					"transitions": [
						{
							"default": "!v.charging_attack"
						},
						{
							"makankosappo_launch": "!v.is_first_person && v.charging_attack == -1"
						}
					]
				},
				"makankosappo_launch": {
					"blend_transition": 0.2,
					"animations": [ "makankosappo_launch" ],
					"transitions": [
						{
							"default": "q.any_animation_finished"
						}
					]
				}
			}
		}
	}
}