{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.player.final_flash": {
			"states": {
				"default": {
					"blend_transition": 0.2,
					"transitions": [
						{
							"first_person_final_flash": "v.is_first_person && v.charging_attack == 7"
						},
						{
							"third_person_final_flash": "!v.is_first_person && v.charging_attack == 7"
						}
					]
				},
				"first_person_final_flash": {
					"blend_transition": 0.2,
					"animations": [
						"ki_attack_setup",
						"first_person_final_flash"
					],
					"particle_effects": [
						{
							"effect": "beam",
							"locator": "leftkiball"
						},
						{
							"effect": "beam",
							"locator": "rightkiball"
						}
					],
					"transitions": [
						{
							"default": "!v.charging_attack"
						},
						{
							"third_person_final_flash": "!v.is_first_person && v.charging_attack"
						}
					]
				},
				"third_person_final_flash": {
					"blend_transition": 0.2,
					"animations": [
						"ki_attack_setup",
						"final_flash"
					],
					"particle_effects": [
						{
							"effect": "beam",
							"locator": "leftkiball"
						},
						{
							"effect": "beam",
							"locator": "rightkiball"
						}
					],
					"transitions": [
						{
							"default": "!v.charging_attack"
						},
						{
							"first_person_final_flash": "v.is_first_person && v.charging_attack"
						},
						{
							"third_person_final_flash_launch": "!v.is_first_person && v.charging_attack == -1"
						}
					]
				},
				"third_person_final_flash_launch": {
					"blend_transition": 0.2,
					"animations": [ "final_flash_launch" ],
					"transitions": [
						{
							"default": "q.any_animation_finished"
						}
					]
				}
			}
		}
	}
}