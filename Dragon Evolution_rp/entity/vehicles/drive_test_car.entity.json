{
    "format_version": "1.10.0",
    "minecraft:client_entity": {
        "description": {
            "identifier": "dbe:drive_test_car",
            "materials": {
                "default": "entity_emissive_alpha"
            },
            "textures": {
                "default": "textures/entity/vehicles/drive_test_car/yellow_drive_test_car"
            },
            "geometry": {
                "default": "geometry.drive_test_car"
            },
            "scripts": {
                "pre_animation": [
                    "v.rotation_x = q.property('dbe:rotation_x');",
                    "v.rotation_z = q.property('dbe:rotation_z');",
                    "v.wheel_rotation = q.property('dbe:wheel_rotation');",
                    "v.wheel_speed = q.property('dbe:wheel_speed') * 2500;"
                ],
                "animate": [
                    "move"
                ]
            },
            "animations": {
                "move": "animation.car.move"
            },
            "render_controllers": [
                "controller.render.default"
            ]
        }
    }
}