{
    "format_version": "1.10.0",
    "minecraft:client_entity": {
        "description": {
            "identifier": "dbe:shisami",
            "materials": {
                "default": "entity_alphatest",
                "alphablend": "entity_alphablend",
                "outline": "outline"
            },
            "textures": {
                "default": "textures/entity/opponents/shisami",
                "ki_attack": "textures/entity/ki_attack"
            },
            "geometry": {
                "default": "geometry.shisami",
                "ki_manipulation": "geometry.ki_manipulation",
                "ki_manipulation_outline": "geometry.ki_manipulation_outline"
            },
            "particle_effects": {
                "beam": "dbe:beam"
            },
            "sound_effects": {
                "kienzan_loop": "skill.kienzan_loop"
            },
            "scripts": {
                "initialize": [
                    "v.ki_blast_hand = 0.0;"
                ],
                "pre_animation": [
                    // colors
                    "v.color0.value = q.property('dbe:color_0');",
                    "v.color1.value = q.property('dbe:color_1');",
                    "v.color2.value = q.property('dbe:color_2');",
                    "v.color3.value = q.property('dbe:color_3');",
                    "v.color0.r = (math.floor(v.color0.value / 1000000) - 100) / 255;",
                    "v.color0.g = (math.floor(math.mod(v.color0.value, 1000000) / 1000) - 100) / 255;",
                    "v.color0.b = (math.mod(v.color0.value, 1000) - 100) / 255;",
                    "v.color1.r = (math.floor(v.color1.value / 1000000) - 100) / 255;",
                    "v.color1.g = (math.floor(math.mod(v.color1.value, 1000000) / 1000) - 100) / 255;",
                    "v.color1.b = (math.mod(v.color1.value, 1000) - 100) / 255;",
                    "v.color2.r = (math.floor(v.color2.value / 1000000) - 100) / 255;",
                    "v.color2.g = (math.floor(math.mod(v.color2.value, 1000000) / 1000) - 100) / 255;",
                    "v.color2.b = (math.mod(v.color2.value, 1000) - 100) / 255;",
                    "v.color3.r = (math.floor(v.color3.value / 1000000) - 100) / 255;",
                    "v.color3.g = (math.floor(math.mod(v.color3.value, 1000000) / 1000) - 100) / 255;",
                    "v.color3.b = (math.mod(v.color3.value, 1000) - 100) / 255;",
                    "v.aura_color.r = v.color0.r;",
                    "v.aura_color.g = v.color0.g;",
                    "v.aura_color.b = v.color0.b;",
                    "v.ki_attack_color0.value = q.property('dbe:ki_attack_color_0');",
                    "v.ki_attack_color1.value = q.property('dbe:ki_attack_color_1');",
                    "v.ki_attack_color0.r = (math.floor(v.ki_attack_color0.value / 1000000) - 100) / 255;",
                    "v.ki_attack_color0.g = (math.floor(math.mod(v.ki_attack_color0.value, 1000000) / 1000) - 100) / 255;",
                    "v.ki_attack_color0.b = (math.mod(v.ki_attack_color0.value, 1000) - 100) / 255;",
                    "v.ki_attack_color1.r = (math.floor(v.ki_attack_color1.value / 1000000) - 100) / 255;",
                    "v.ki_attack_color1.g = (math.floor(math.mod(v.ki_attack_color1.value, 1000000) / 1000) - 100) / 255;",
                    "v.ki_attack_color1.b = (math.mod(v.ki_attack_color1.value, 1000) - 100) / 255;",
                    // common
                    "v.aura_enabled = q.property('dbe:aura_boost');",
                    "v.charging_attack = q.property('dbe:charging_attack');",
                    "v.is_falling = q.vertical_speed < -0.2;",
                    "v.is_flying = q.property('dbe:is_flying') && !v.charging_attack;",
                    "v.is_idle = !q.ground_speed && !v.charging_attack;",
                    "v.is_knocked_out = q.property('dbe:is_knocked_out');",
                    "v.is_sprinting = q.property('dbe:aura_boost') && !v.charging_attack;",
                    "v.is_walking = q.ground_speed && !v.charging_attack;",
                    "v.transformation = q.property('dbe:transformation');"
                ],
                "animate": [
                    "root"
                ]
            },
            "animations": {
                "root": "controller.animation.common_enemy.root",
                "attack_controller": "controller.animation.common_enemy.attack",
                "blink": "animation.humanoid.blink",
                "fall": "animation.player.fall",
                "final_flash": "animation.attack_poses.final_flash",
                "final_flash_launch": "animation.attack_poses.final_flash_launch",
                "fly_controller": "controller.animation.common_enemy.fly",
                "fly_idle": "animation.player.fly.idle",
                "fly_sprinting": "animation.player.fly.sprinting",
                "fly_walking": "animation.player.fly.walking",
                "galick_gun": "animation.attack_poses.galick_gun",
                "galick_gun_launch": "animation.attack_poses.galick_gun_launch",
                "genki_dama": "animation.attack_poses.genki_dama",
                "idle": "animation.player.idle",
                "idle_controller": "controller.animation.common_enemy.idle",
                "jump": "animation.player.jump",
                "jump_controller": "controller.animation.common_enemy.jump",
                "kienzan": "animation.attack_poses.kienzan",
                "kamehameha_launch": "animation.attack_poses.kamehameha_launch",
                "kamehameha": "animation.attack_poses.kamehameha",
                "ki_attack_controller": "controller.animation.common_enemy.ki_attack",
                "ki_attack_setup": "animation.attack_poses.setup",
                "ki_blast_left": "animation.attack_poses.ki_blast_left",
                "ki_blast_right": "animation.attack_poses.ki_blast_right",
                "knocked_out": "animation.humanoid.knocked_out",
                "land": "animation.player.land",
                "makankosappo": "animation.attack_poses.makankosappo",
                "makankosappo_launch": "animation.attack_poses.makankosappo_launch",
                "melee_attack_1": "animation.player.melee.attack_1",
                "melee_attack_2": "animation.player.melee.attack_2",
                "melee_attack_3": "animation.player.melee.attack_3",
                "melee_attack_4": "animation.player.melee.attack_4",
                "melee_attack_5": "animation.player.melee.attack_5",
                "melee_attack_6": "animation.player.melee.attack_6",
                "sprint": "animation.player.sprint",
                "walk": "animation.player.walk",
                "walk_controller": "controller.animation.common_enemy.walk"
            },
            "render_controllers": [
                "controller.render.default",
                { "controller.render.player.ki_manipulation": "v.charging_attack" },
                { "controller.render.player.ki_manipulation.outline": "v.charging_attack" }
            ]
        }
    }
}