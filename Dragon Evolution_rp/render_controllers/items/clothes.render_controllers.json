{
    "format_version": "1.8.0",
    "render_controllers": {
        "controller.render.clothes": {
            "geometry": "Geometry.default",
            "materials": [ { "*": "Material.default" } ],
            "textures": [ "Texture.default" ],
            "part_visibility": [
                { "*": "q.has_property('dbe:is_armor_visible') ? q.property('dbe:is_armor_visible') : 'true'" },
                { "breasts": "q.has_property('dbe:gender') ? q.property('dbe:gender') : 'false'" }
            ]
        },
        "controller.render.christmas_costume": {
            "arrays": {
                "textures": {
                    "Array.male_christmas_costume": [
                        "Texture.christmas_costume_1",
                        "Texture.christmas_costume_2",
                        "Texture.christmas_costume_4",
                        "Texture.christmas_costume_5"
                    ],
                    "Array.female_christmas_costume": [
                        "Texture.christmas_costume_3",
                        "Texture.christmas_costume_6"
                    ]
                }
            },
            "geometry": "Geometry.default",
            "materials": [ { "*": "Material.default" } ],
            "textures": [ "q.has_property('dbe:gender') ? q.property('dbe:gender') ? Array.female_christmas_costume[q.has_property('dbe:customization_0') ? q.property('dbe:customization_0') : 0] : Array.male_christmas_costume[q.has_property('dbe:customization_0') ? q.property('dbe:customization_0') : 0] : Texture.christmas_costume_1" ],
            "part_visibility": [
                { "*": "q.has_property('dbe:is_armor_visible') ? q.property('dbe:is_armor_visible') : 'true'" },
                { "breasts": "q.has_property('dbe:gender') ? q.property('dbe:gender') : 'false'" }
            ]
        },
        "controller.render.dyed_clothes": {
            "geometry": "Geometry.default",
            "materials": [ { "*": "v.is_dyed ? Material.dyed : Material.default" } ],
            "textures": [ "v.is_dyed ? Texture.dyed : Texture.default" ],
            "part_visibility": [
                { "*": "q.has_property('dbe:is_armor_visible') ? q.property('dbe:is_armor_visible') : 'true'" },
                { "breasts": "q.has_property('dbe:gender') ? q.property('dbe:gender') : 'false'" }
            ]
        },
        "controller.render.female_clothes": {
            "geometry": "Geometry.default",
            "materials": [ { "*": "Material.default" } ],
            "textures": [ "Texture.female_clothes" ],
            "part_visibility": [
                { "*": "q.has_property('dbe:is_armor_visible') ? q.property('dbe:is_armor_visible') : 'true'" }
            ]
        }
    }
}