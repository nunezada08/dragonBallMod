{
    "format_version": "1.8.0",
    "render_controllers": {
        "controller.render.player.namekian.eyes": {
            "arrays": {
                "textures": {
                    "Array.eyes": [
                        "Texture.namekian_eyes",
                        "Texture.namekian_eyes",
                        "Texture.namekian_eyes_potential_unleashed",
                        "Texture.namekian_eyes_ultimate_form",
                        "Texture.namekian_eyes_orange_form",
                        "Texture.namekian_eyes_beast_form",
                        "Texture.namekian_eyes_beast_form"
                    ]
                }
            },
            "geometry": "Geometry.eyes",
            "materials": [
                { "*": "Material.default" },
                { "leftEye": "material.emissive" },
                { "rightEye": "material.emissive" }
            ],
            "textures": [ "v.ultra_instinct ? Texture.namekian_eyes_ultra_instinct : Array.eyes[v.transformation]" ]
        },
        "controller.render.player.namekian.first_person": {
            "arrays": {
                "textures": {
                    "Array.skins": [
                        "Texture.namekian_skin_1",
                        "Texture.namekian_skin_2",
                        "Texture.namekian_skin_3",
                        "Texture.namekian_skin_4"
                    ],
                    "Array.beast_skins": [
                        "Texture.namekian_skin_beast_form_1",
                        "Texture.namekian_skin_beast_form_2",
                        "Texture.namekian_skin_beast_form_3",
                        "Texture.namekian_skin_beast_form_4"
                    ],
                    "Array.transformation_overlay": [
                        "Texture.namekian_skin_detail",
                        "Texture.namekian_skin_detail",
                        "Texture.namekian_skin_potential_unleashed_detail",
                        "Texture.namekian_skin_detail",
                        "Texture.namekian_skin_potential_unleashed_detail",
                        "Texture.namekian_skin_detail",
                        "Texture.namekian_skin_detail"
                    ]
                }
            },
            "geometry": "Geometry.namekian",
            "materials": [ { "*": "Material.masked" } ],
            "textures": [
                "v.transformation == 6 ? Texture.namekian_skin_ultra_ego : v.transformation == 5 ? Array.beast_skins[v.customization0] : v.transformation == 4 ? Texture.namekian_skin_orange_form : v.transformation == 2 ? Texture.namekian_skin_potential_unleashed : Array.skins[v.customization0]",
                "Array.transformation_overlay[v.transformation]",
                "Texture.empty"
            ],
            "part_visibility": [
                { "*": false },
                { "rightArm": "v.rightarm_visible || q.get_equipped_item_name(0, 1) == '' || q.get_equipped_item_name(0, 1) == 'map'" },
                { "rightForearm": "v.rightarm_visible || q.get_equipped_item_name(0, 1) == '' || q.get_equipped_item_name(0, 1) == 'map'" },
                { "leftArm": "v.leftarm_visible || (q.get_equipped_item_name(0, 1) == 'map' && q.get_equipped_item_name('off_hand') != 'shield') || (q.get_equipped_item_name('off_hand') == 'map' && !q.item_is_charged) || (!q.item_is_charged && (v.item_use_normalized > 0 && v.item_use_normalized < 1.0))" },
                { "leftForearm": "v.leftarm_visible || (q.get_equipped_item_name(0, 1) == 'map' && q.get_equipped_item_name('off_hand') != 'shield') || (q.get_equipped_item_name('off_hand') == 'map' && !q.item_is_charged) || (!q.item_is_charged && (v.item_use_normalized > 0 && v.item_use_normalized < 1.0))" }
            ],
            "overlay_color": {
                "r": "v.is_hakai ? 0.65 : v.kaioken_enabled ? 1 : 0",
                "g": 0,
                "b": "v.is_hakai ? 0.8 : 0",
                "a": "(v.is_hakai || v.kaioken_enabled) ? 0.2 : 0"
            }
        },
        "controller.render.player.namekian.third_person": {
            "arrays": {
                "textures": {
                    "Array.skins": [
                        "Texture.namekian_skin_1",
                        "Texture.namekian_skin_2",
                        "Texture.namekian_skin_3",
                        "Texture.namekian_skin_4"
                    ],
                    "Array.beast_skins": [
                        "Texture.namekian_skin_beast_form_1",
                        "Texture.namekian_skin_beast_form_2",
                        "Texture.namekian_skin_beast_form_3",
                        "Texture.namekian_skin_beast_form_4"
                    ],
                    "Array.transformation_overlay": [
                        "Texture.namekian_skin_detail",
                        "Texture.namekian_skin_detail",
                        "Texture.namekian_skin_potential_unleashed_detail",
                        "Texture.namekian_skin_detail",
                        "Texture.namekian_skin_potential_unleashed_detail",
                        "Texture.namekian_skin_detail",
                        "Texture.namekian_skin_detail"
                    ]
                }
            },
            "geometry": "Geometry.namekian",
            "materials": [ { "*": "Material.masked" } ],
            "textures": [
                "v.transformation == 6 ? Texture.namekian_skin_ultra_ego : v.transformation == 5 ? Array.beast_skins[v.customization0] : v.transformation == 4 ? Texture.namekian_skin_orange_form : v.transformation == 2 ? Texture.namekian_skin_potential_unleashed : Array.skins[v.customization0]",
                "Array.transformation_overlay[v.transformation]",
                "Texture.empty"
            ],
            "part_visibility": [
                { "*": true },
                { "leftAntenna": "!v.hide_hair" },
                { "rightAntenna": "!v.hide_hair" },
                { "leftEar": "!v.hide_left_ear" },
                { "rightEar": "!v.hide_right_ear" }
            ],
            "overlay_color": {
                "r": "v.is_hakai ? 0.65 : v.kaioken_enabled ? 1 : 0",
                "g": 0,
                "b": "v.is_hakai ? 0.8 : 0",
                "a": "(v.is_hakai || v.kaioken_enabled) ? 0.2 : 0"
            }
        }
    }
}