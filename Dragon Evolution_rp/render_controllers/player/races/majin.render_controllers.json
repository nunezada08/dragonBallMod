            "part_visibility": [
                { "*": true },
                { "*antenna*": "!v.hide_hair && v.transformation < 2" },
                { "*bigAntenna*": "!v.hide_hair && v.transformation >= 2" },
                { "breasts": "v.is_female" },
                { "leftEar": "!v.hide_left_ear" },
                { "rightEar": "!v.hide_right_ear" }
            ],
            "overlay_color": {
