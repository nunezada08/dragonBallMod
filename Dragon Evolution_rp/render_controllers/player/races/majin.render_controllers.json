{
    "format_version": "1.8.0",
    "render_controllers": {
        "controller.render.player.majin.eyes_iris": {
            "geometry": "Geometry.eyes",
            "materials": [ { "*": "Material.alphatest_change_color" } ],
            "textures": [ "v.is_female ? Texture.majin_eyes_female : Texture.majin_eyes_male" ],
            "part_visibility": [
                { "*": false },
                { "leftIris": true },
                { "rightIris": true }
            ],
            "color": {
                "r": "v.color2.r",
                "g": "v.color2.g",
                "b": "v.color2.b"
            }
        },
        "controller.render.player.majin.eyes_sclera": {
            "geometry": "Geometry.eyes",
            "materials": [ { "*": "Material.default" } ],
            "textures": [ "v.is_female ? Texture.majin_eyes_female : Texture.majin_eyes_male" ],
            "part_visibility": [
                { "*": false },
                { "leftEye": true },
                { "rightEye": true }
            ]
        },
        "controller.render.player.majin.first_person": {
            "arrays": {
                "textures": {
                    "Array.female_skins": [
                        "Texture.majin_skin_female_1",
                        "Texture.majin_skin_female_2",
                        "Texture.majin_skin_female_3",
                        "Texture.majin_skin_female_4",
