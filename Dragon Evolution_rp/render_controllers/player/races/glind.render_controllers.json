{
    "format_version": "1.8.0",
    "render_controllers": {
        "controller.render.player.glind.eyebrows": {
            "geometry": "Geometry.eyes",
            "materials": [ { "*": "Material.alphatest_change_color" } ],
            "textures": [ "v.is_female ? Texture.glind_eyes_female : Texture.glind_eyes_male" ],
            "part_visibility": [
                { "*": false },
                { "eyebrows": true }
            ],
            "color": {
                "r": "v.color1.r",
                "g": "v.color1.g",
                "b": "v.color1.b"
            }
        },
        "controller.render.player.glind.eyes_iris": {
            "geometry": "Geometry.eyes",
            "materials": [ { "*": "Material.alphatest_change_color" } ],
            "textures": [ "v.is_female ? Texture.glind_eyes_female : Texture.glind_eyes_male" ],
            "part_visibility": [
                { "*": false },
                { "leftIris": true },
                { "rightIris": true }
            ],
            "color": {
                "r": "v.color2.r",
                "g": "v.color2.g",
                "b": "v.color2.b"
            }
        },
        "controller.render.player.glind.eyes_sclera": {
            "geometry": "Geometry.eyes",
            "materials": [ { "*": "Material.default" } ],
            "textures": [ "v.is_female ? Texture.glind_eyes_female : Texture.glind_eyes_male" ],
            "part_visibility": [
                { "*": false },
                { "leftEye": true },
                { "rightEye": true }
            ]
        },
        "controller.render.player.glind.first_person": {
            "arrays": {
                "textures": {
                    "Array.skins": [
                        "Texture.glind_skin_1",
                        "Texture.glind_skin_2",
                        "Texture.glind_skin_3",
                        "Texture.glind_skin_4"
                    ]
                }
            },
            "geometry": "Geometry.glind",
            "materials": [ { "*": "Material.default" } ],
            "textures": [ "Array.skins[v.customization0]" ],
            "part_visibility": [
                { "*": false },
                { "rightArm": "v.rightarm_visible || q.get_equipped_item_name(0, 1) == '' || q.get_equipped_item_name(0, 1) == 'map'" },
                { "rightForearm": "v.rightarm_visible || q.get_equipped_item_name(0, 1) == '' || q.get_equipped_item_name(0, 1) == 'map'" },
                { "leftArm": "v.leftarm_visible || (q.get_equipped_item_name(0, 1) == 'map' && q.get_equipped_item_name('off_hand') != 'shield') || (q.get_equipped_item_name('off_hand') == 'map' && !q.item_is_charged) || (!q.item_is_charged && (v.item_use_normalized > 0 && v.item_use_normalized < 1.0))" },
                { "leftForearm": "v.leftarm_visible || (q.get_equipped_item_name(0, 1) == 'map' && q.get_equipped_item_name('off_hand') != 'shield') || (q.get_equipped_item_name('off_hand') == 'map' && !q.item_is_charged) || (!q.item_is_charged && (v.item_use_normalized > 0 && v.item_use_normalized < 1.0))" }
            ],
            "overlay_color": {
                "r": "v.is_hakai ? 0.65 : v.kaioken_enabled ? 1 : 0",
                "g": 0,
                "b": "v.is_hakai ? 0.8 : 0",
                "a": "(v.is_hakai || v.kaioken_enabled) ? 0.2 : 0"
            }
        },
        "controller.render.player.glind.hair": {
            "arrays": {
                "geometries": {
                    "Array.geometries": [
                        "Geometry.fused_zamasu_hair",
                        "Geometry.fused_fused_zamasu_hair"
                    ]
                },
                "textures": {
                    "Array.textures": [
                        "Texture.glind_hair_1",
                        "Texture.glind_hair_2"
                    ]
                }
            },
            "geometry": "Array.geometries[v.customization1]",
            "materials": [ { "*": "Material.alphatest_change_color" } ],
            "textures": [ "Array.textures[v.customization1]" ],
            "part_visibility": [
                { "*": "!v.hide_hair" },
                { "head": true }
            ],
            "color": {
                "r": "v.color1.r",
                "g": "v.color1.g",
                "b": "v.color1.b"
            }
        },
        "controller.render.player.glind.third_person": {
            "arrays": {
                "textures": {
                    "Array.skins": [
                        "Texture.glind_skin_1",
                        "Texture.glind_skin_2",
                        "Texture.glind_skin_3",
                        "Texture.glind_skin_4"
                    ]
                }
            },
            "geometry": "Geometry.glind",
            "materials": [ { "*": "Material.default" } ],
            "textures": [ "Array.skins[v.customization0]" ],
            "part_visibility": [
                { "*": true },
                { "breasts": "v.is_female" },
                { "leftEar": "!v.hide_left_ear" },
                { "rightEar": "!v.hide_right_ear" }
            ],
            "overlay_color": {
                "r": "v.is_hakai ? 0.65 : v.kaioken_enabled ? 1 : 0",
                "g": 0,
                "b": "v.is_hakai ? 0.8 : 0",
                "a": "(v.is_hakai || v.kaioken_enabled) ? 0.2 : 0"
            }
        }
    }
}