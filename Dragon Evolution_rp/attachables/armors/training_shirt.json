{
    "format_version": "1.26.0",
    "minecraft:attachable": {
        "description": {
            "identifier": "dbe:training_shirt",
            "materials": {
                "default": "armor"
            },
            "textures": {
                "default": "textures/models/armors/training_shirt"
            },
            "geometry": {
                "default": "geometry.training_shirt"
            },
            "render_controllers": [
                {
                    "controller.render.clothes": "q.is_item_name_any('slot.weapon.offhand', 0, 'dbe:training_shirt') && !c.is_first_person"
                }
            ]
        }
    }
}