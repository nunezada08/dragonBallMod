{
    "format_version": "1.26.0",
    "minecraft:attachable": {
        "description": {
            "identifier": "dbe:battle_chestplate",
            "materials": {
                "default": "armor",
                "dyed": "entity_alphatest_change_color"
            },
            "textures": {
                "default": "textures/models/armors/battle_armor/battle_armor",
                "dyed": "textures/models/armors/battle_armor/battle_armor_grayscale",
                "dyed_oozaru_armor": "textures/models/armors/oozaru_clothes/oozaru_battle_armor_grayscale",
                "oozaru_armor": "textures/models/armors/oozaru_clothes/oozaru_battle_armor"
            },
            "geometry": {
                "default": "geometry.battle_armor.chestplate",
                "oozaru_armor": "geometry.oozaru_clothes.chestplate"
            },
            "scripts": {
                "parent_setup": "v.chest_layer_visible = 0;",
                "pre_animation": [
                    "v.is_dyed = q.armor_color_slot(1, 0) != 1 || q.armor_color_slot(1, 1) != 1 || q.armor_color_slot(1, 2) != 1 || q.armor_color_slot(1, 3) != 1;",
                    "v.is_oozaru = q.has_property('dbe:race') && q.has_property('dbe:transformation') ? q.property('dbe:race') == 'saiyan' && q.any(q.property('dbe:transformation'), 1, 8) : 0.0;"
                ],
                "animate": [
                    "offset"
                ]
            },
            "animations": {
                "offset": "animation.armor.chestplate.offset"
            },
            "render_controllers": [
                {
                    "controller.render.dyed_clothes": "!v.is_oozaru"
                },
                {
                    "controller.render.dyed_oozaru_armor": "v.is_oozaru"
                }
            ]
        }
    }
}