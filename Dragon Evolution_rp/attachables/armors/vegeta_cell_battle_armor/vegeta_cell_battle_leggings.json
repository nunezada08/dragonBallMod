{
    "format_version": "1.26.0",
    "minecraft:attachable": {
        "description": {
            "identifier": "dbe:vegeta_cell_battle_leggings",
            "materials": {
                "default": "armor"
            },
            "textures": {
                "default": "textures/models/armors/battle_armor/vegeta_cell_battle_armor",
                "oozaru_armor": "textures/models/armors/oozaru_clothes/oozaru_vegeta_cell_battle_armor"
            },
            "geometry": {
                "default": "geometry.battle_armor.leggings",
                "oozaru_armor": "geometry.oozaru_clothes.leggings"
            },
            "scripts": {
                "parent_setup": "v.leg_layer_visible = 0.0;",
                "pre_animation": [
                    "v.is_oozaru = q.has_property('dbe:race') && q.has_property('dbe:transformation') ? q.property('dbe:race') == 'saiyan' && q.any(q.property('dbe:transformation'), 1, 8) : 0.0;"
                ],
                "animate": [
                    "offset"
                ]
            },
            "animations": {
                "offset": "animation.armor.leggings.offset"
            },
            "render_controllers": [
                {
                    "controller.render.clothes": "!v.is_oozaru"
                },
                {
                    "controller.render.oozaru_armor": "v.is_oozaru"
                }
            ]
        }
    }
}