{
    "namespace": "npc_skills_form",

    "npc_skills_form": {
        "type": "panel",
        "controls": [
            {
                "background": {
                    "size": [ "100%", "100%" ],
                    "type": "image",
                    "texture": "textures/ui/backgrounds/black_background",
                    "alpha": 0.75
                }
            },
            {
                "form@server_form.long_form": {
                    "size": [ 275, 175 ],
                    "$child_control": "npc_skills_form.npc_skills_scrolling_panel",
                    "$custom_background": "custom_server_form.background",
                    "$background_texture": "textures/ui/backgrounds/menu_background",
                    "$default_button_texture": "textures/ui/buttons/menu_button",
                    "$hover_button_texture": "textures/ui/buttons/menu_button_hover"
                }
            }
        ]
    },

    "npc_skills_scrolling_panel": {
        "type": "panel",
        "layer": 1,
        "controls": [
            {
                "back_button@custom_server_form.back_button": { }
            },
            {
                "scrolling_panel@common.scrolling_panel": {
                    "anchor_to": "top_middle",
                    "anchor_from": "top_middle",
                    "size": [ "100%", "100%" ],
                    "$show_background": false,
                    "$scrolling_content": "npc_skills_form.npc_skills_form_scrolling_content",
                    "$scroll_size": [ 5, "100% - 4px" ],
                    "$scrolling_pane_size": [ "100% - 4px", "100% - 2px" ],
                    "$scrolling_pane_offset": [ 2, 0 ],
                    "$scroll_bar_right_padding_size": [ 0, 0 ]
                }
            }
        ]
    },

    "npc_skills_form_scrolling_content": {
        "type": "panel",
        "size": [ "100% - 4px", "100%c" ],
        "controls": [
            {
                "buttons_panel": {
                    "type": "stack_panel",
                    "factory": {
                        "name": "buttons",
                        "control_name": "npc_skills_form.button"
                    },
                    "collection_name": "form_buttons",
                    "bindings": [
                        {
                            "binding_name": "#form_button_length",
                            "binding_name_override": "#collection_length"
                        }
                    ]
                }
            }
        ]
    },

    "button@custom_server_form.text_button": {
        "size": [ "100%", 50 ]
    }
}