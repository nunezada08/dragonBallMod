            { "39@common_bar.bar_image": { "$condition": "($bar_prefix + '39')", "$bar_clip_ratio": 0.22 } },
            { "40@common_bar.bar_image": { "$condition": "($bar_prefix + '40')", "$bar_clip_ratio": 0.2 } },
            { "41@common_bar.bar_image": { "$condition": "($bar_prefix + '41')", "$bar_clip_ratio": 0.18 } },
            { "42@common_bar.bar_image": { "$condition": "($bar_prefix + '42')", "$bar_clip_ratio": 0.16 } },
            { "43@common_bar.bar_image": { "$condition": "($bar_prefix + '43')", "$bar_clip_ratio": 0.14 } },
            { "44@common_bar.bar_image": { "$condition": "($bar_prefix + '44')", "$bar_clip_ratio": 0.12 } },
