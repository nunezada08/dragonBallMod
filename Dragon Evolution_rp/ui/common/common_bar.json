{

    "namespace": "common_bar",

    "bar_panel": {
        "type": "panel",
        "$bar_prefix|default": "common_bar:",
        "$bar_texture|default": "textures/empty",
        "$bar_offset|default": [ 0, 0 ],
        "$bar_size|default": [ "100%", "100%" ],
        "$bar_anchor_from|default": "center",
        "$bar_anchor_to|default": "center",
        "$bar_uv|default": [ 0, 0 ],
        "$bar_uv_size|default": [ "100%", "100%" ],
        "$bar_layer|default": 0,
        "$bar_clip_ratio|default": 1,
        "$bar_clip_direction|default": "left",
        "controls": [
            { "0@common_bar.bar_image": { "$condition": "($bar_prefix + '0')", "$bar_clip_ratio": 1 } },
            { "1@common_bar.bar_image": { "$condition": "($bar_prefix + '1')", "$bar_clip_ratio": 0.98 } },
            { "2@common_bar.bar_image": { "$condition": "($bar_prefix + '2')", "$bar_clip_ratio": 0.96 } },
            { "3@common_bar.bar_image": { "$condition": "($bar_prefix + '3')", "$bar_clip_ratio": 0.94 } },
            { "4@common_bar.bar_image": { "$condition": "($bar_prefix + '4')", "$bar_clip_ratio": 0.92 } },
            { "5@common_bar.bar_image": { "$condition": "($bar_prefix + '5')", "$bar_clip_ratio": 0.9 } },
