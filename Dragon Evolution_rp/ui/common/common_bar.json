            { "10@common_bar.bar_image": { "$condition": "($bar_prefix + '10')", "$bar_clip_ratio": 0.8 } },
            { "11@common_bar.bar_image": { "$condition": "($bar_prefix + '11')", "$bar_clip_ratio": 0.78 } },
            { "12@common_bar.bar_image": { "$condition": "($bar_prefix + '12')", "$bar_clip_ratio": 0.76 } },
            { "13@common_bar.bar_image": { "$condition": "($bar_prefix + '13')", "$bar_clip_ratio": 0.74 } },
            { "14@common_bar.bar_image": { "$condition": "($bar_prefix + '14')", "$bar_clip_ratio": 0.72 } },
            { "15@common_bar.bar_image": { "$condition": "($bar_prefix + '15')", "$bar_clip_ratio": 0.7 } },
            { "16@common_bar.bar_image": { "$condition": "($bar_prefix + '16')", "$bar_clip_ratio": 0.68 } },
            { "17@common_bar.bar_image": { "$condition": "($bar_prefix + '17')", "$bar_clip_ratio": 0.66 } },
            { "18@common_bar.bar_image": { "$condition": "($bar_prefix + '18')", "$bar_clip_ratio": 0.64 } },
            { "19@common_bar.bar_image": { "$condition": "($bar_prefix + '19')", "$bar_clip_ratio": 0.62 } },
            { "20@common_bar.bar_image": { "$condition": "($bar_prefix + '20')", "$bar_clip_ratio": 0.6 } },
            { "21@common_bar.bar_image": { "$condition": "($bar_prefix + '21')", "$bar_clip_ratio": 0.58 } },
            { "22@common_bar.bar_image": { "$condition": "($bar_prefix + '22')", "$bar_clip_ratio": 0.56 } },
            { "23@common_bar.bar_image": { "$condition": "($bar_prefix + '23')", "$bar_clip_ratio": 0.54 } },
            { "24@common_bar.bar_image": { "$condition": "($bar_prefix + '24')", "$bar_clip_ratio": 0.52 } },
            { "25@common_bar.bar_image": { "$condition": "($bar_prefix + '25')", "$bar_clip_ratio": 0.5 } },
