            { "27@common_bar.bar_image": { "$condition": "($bar_prefix + '27')", "$bar_clip_ratio": 0.46 } },
            { "28@common_bar.bar_image": { "$condition": "($bar_prefix + '28')", "$bar_clip_ratio": 0.44 } },
