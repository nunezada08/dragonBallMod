{
    "format_version": "1.26.0",
    "minecraft:block": {
        "description": {
            "identifier": "dbe:dirtstone",
            "states": {
                "dbe:dirtstone_type": [ 0, 1 ]
            }
        },

        "components": {
            "minecraft:geometry": "minecraft:geometry.full_block",
            "minecraft:light_dampening": 15,
            "minecraft:loot": "loot_tables/blocks/dirtstone.json",
            "minecraft:map_color": "#745042",
            "minecraft:destructible_by_explosion": {
                "explosion_resistance": 1.5
            },
            "minecraft:destructible_by_mining": {
                "seconds_to_destroy": 1.5
            },
            "minecraft:redstone_conductivity": {
                "allows_wire_to_step_down": true,
                "redstone_conductor": true
            },
            "minecraft:material_instances": {
                "*": {
                    "texture": "dirtstone"
                }
            },
            "tag:minecraft:is_pickaxe_item_destructible": { },
            "tag:stone": { }
        },

        "permutations": [
            {
                "condition": "q.block_state('dbe:dirtstone_type') == 1",
                "components": {
                    "minecraft:material_instances": {
                        "*": {
                            "texture": "dirtstone_light"
                        }
                    }
                }
            }
        ]
    }
}