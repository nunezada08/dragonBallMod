{
    "format_version": "1.26.0",
    "minecraft:block": {
        "description": {
            "identifier": "dbe:namek_mushroom",
            "states": {
                "solariscore:growth": {
                    "values": {
                        "min": 0,
                        "max": 3
                    }
                }
            },
            "traits": {
                "minecraft:placement_direction": {
                    "enabled_states": [ "minecraft:cardinal_direction" ]
                }
            }
        },

        "components": {
            "minecraft:collision_box": false,
            "minecraft:flower_pottable": { },
            "minecraft:light_dampening": 0,
            "minecraft:map_color": "#ce3717",
            "minecraft:connection_rule": {
                "accepts_connections_from": "none"
            },
            "minecraft:destructible_by_explosion": {
                "explosion_resistance": 0
            },
            "minecraft:destructible_by_mining": {
                "seconds_to_destroy": 0
            },
            "minecraft:embedded_visual": {
                "geometry": "geometry.potted_cross",
                "material_instances": {
                    "*": {
                        "texture": "potted_namek_mushroom",
                        "render_method": "alpha_test_single_sided",
                        "ambient_occlusion": false,
                        "face_dimming": false
                    }
                }
            },
            "minecraft:flammable": {
                "catch_chance_modifier": 60,
                "destroy_chance_modifier": 100
            },
            "minecraft:geometry": {
                "identifier": "geometry.namek_mushroom",
                "bone_visibility": {
                    "part0": true,
                    "part1": "q.block_state('solariscore:growth') > 0",
                    "part2": "q.block_state('solariscore:growth') > 1",
                    "part3": "q.block_state('solariscore:growth') > 2"
                }
            },
            "minecraft:liquid_detection": {
                "detection_rules": [
                    {
                        "on_liquid_touches": "popped"
                    }
                ]
            },
            "minecraft:material_instances": {
                "*": {
                    "texture": "namek_mushroom",
                    "render_method": "alpha_test_single_sided",
                    "ambient_occlusion": false,
                    "face_dimming": false
                }
            },
            "minecraft:placement_filter": {
                "conditions": [
                    {
                        "block_filter": [
                            {
                                "tags": "q.any_tag('grass', 'dirt')"
                            }
                        ],
                        "allowed_faces": [ "up" ]
                    }
                ]
            },
            "minecraft:selection_box": {
                "origin": [ -8, 0, -8 ],
                "size": [ 16, 3, 16 ]
            },
            "solariscore:crop": {
                "accumulable": true,
                "bone_meal_multiplication": true,
                "max_stage": 3,
                "natural_growth": false
            },
            "tag:plant": { }
        },

        "permutations": [
            {
                "condition": "q.block_state('minecraft:cardinal_direction') == 'west'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [ 0, -90, 0 ]
                    }
                }
            },
            {
                "condition": "q.block_state('minecraft:cardinal_direction') == 'south'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [ 0, 0, 0 ]
                    }
                }
            },
            {
                "condition": "q.block_state('minecraft:cardinal_direction') == 'east'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [ 0, 90, 0 ]
                    }
                }
            },
            {
                "condition": "q.block_state('minecraft:cardinal_direction') == 'north'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [ 0, 180, 0 ]
                    }
                }
            },
            {
                "condition": "q.block_state('solariscore:growth') == 0",
                "components": {
                    "minecraft:loot": "loot_tables/blocks/namek_mushroom/stage_1.json"
                }
            },
            {
                "condition": "q.block_state('solariscore:growth') == 1",
                "components": {
                    "minecraft:loot": "loot_tables/blocks/namek_mushroom/stage_2.json"
                }
            },
            {
                "condition": "q.block_state('solariscore:growth') == 2",
                "components": {
                    "minecraft:loot": "loot_tables/blocks/namek_mushroom/stage_3.json"
                }
            },
            {
                "condition": "q.block_state('solariscore:growth') == 3",
                "components": {
                    "minecraft:loot": "loot_tables/blocks/namek_mushroom/stage_4.json"
                }
            }
        ]
    }
}