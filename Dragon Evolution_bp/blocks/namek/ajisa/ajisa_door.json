{
	"format_version": "1.26.1",
	"minecraft:block": {
		"description": {
			"identifier": "dbe:ajisa_door",
			"states": {
				"solariscore:door_hinge_bit": [ false, true ],
				"solariscore:open_bit": [ false, true ]
			},
			"traits": {
				"minecraft:multi_block": {
					"enabled_states": [ "minecraft:multi_block_part" ],
					"direction": "up",
					"parts": 2
				},
				"minecraft:placement_direction": {
					"enabled_states": [ "minecraft:cardinal_direction" ]
				}
			}
		},

		"components": {
			"minecraft:loot": "loot_tables/blocks/ajisa_door.json",
			"minecraft:collision_box": {
				"origin": [ -8, 0, -8 ],
				"size": [ 16, 16, 3 ]
			},
			"minecraft:connection_rule": {
				"accepts_connections_from": "none"
			},
			"minecraft:geometry": {
				"identifier": "geometry.door",
				"bone_visibility": {
					"bottom": "!q.block_state('solariscore:open_bit') && q.block_state('minecraft:multi_block_part') == 0 && !q.block_state('solariscore:door_hinge_bit')",
					"open_bottom": "q.block_state('solariscore:open_bit') && q.block_state('minecraft:multi_block_part') == 0 && !q.block_state('solariscore:door_hinge_bit')",
					"open_top": "q.block_state('solariscore:open_bit') && q.block_state('minecraft:multi_block_part') == 1 && !q.block_state('solariscore:door_hinge_bit')",
					"reversed_bottom": "!q.block_state('solariscore:open_bit') && q.block_state('minecraft:multi_block_part') == 0 && q.block_state('solariscore:door_hinge_bit')",
					"reversed_open_bottom": "q.block_state('solariscore:open_bit') && q.block_state('minecraft:multi_block_part') == 0 && q.block_state('solariscore:door_hinge_bit')",
					"reversed_open_top": "q.block_state('solariscore:open_bit') && q.block_state('minecraft:multi_block_part') == 1 && q.block_state('solariscore:door_hinge_bit')",
					"reversed_top": "!q.block_state('solariscore:open_bit') && q.block_state('minecraft:multi_block_part') == 1 && q.block_state('solariscore:door_hinge_bit')",
					"top": "!q.block_state('solariscore:open_bit') && q.block_state('minecraft:multi_block_part') == 1 && !q.block_state('solariscore:door_hinge_bit')"
				}
			},
			"minecraft:flammable": {
				"catch_chance_modifier": 5,
				"destroy_chance_modifier": 20
			},
			"minecraft:liquid_detection": {
				"detection_rules": [
					{
						"can_contain_liquid": true
					}
				]
			},
			"minecraft:material_instances": {
				"*": {
					"texture": "ajisa_door_lower",
					"render_method": "blend"
				}
			},
			"minecraft:movable": {
				"movement_type": "popped"
			},
			// "minecraft:placement_filter": {
			// 	"conditions": [
			// 		{
			// 			"allowed_faces": [ "up" ]
			// 		}
			// 	]
			// },
			"minecraft:destructible_by_mining": {
				"seconds_to_destroy": 0.3
			},
			"minecraft:redstone_consumer": {
				"min_power": 0
			},
			"minecraft:selection_box": {
				"origin": [ -8, 0, -8 ],
				"size": [ 16, 16, 3 ]
			},
			"solariscore:door": { },
			"tag:minecraft:is_axe_item_destructible": { },
			"tag:one_way_collidable": { },
			"tag:wood": { }
		},

		"permutations": [
			{
				"condition": "q.block_state('minecraft:cardinal_direction') == 'north'",
				"components": {
					"minecraft:transformation": {
						"rotation": [ 0, 180, 0 ]
					}
				}
			},
			{
				"condition": "q.block_state('minecraft:cardinal_direction') == 'east'",
				"components": {
					"minecraft:transformation": {
						"rotation": [ 0, 90, 0 ]
					}
				}
			},
			{
				"condition": "q.block_state('minecraft:cardinal_direction') == 'west'",
				"components": {
					"minecraft:transformation": {
						"rotation": [ 0, 270, 0 ]
					}
				}
			},
			{
				"condition": "q.block_state('solariscore:open_bit') && !q.block_state('solariscore:door_hinge_bit')",
				"components": {
					"minecraft:collision_box": {
						"origin": [ -8, 0, -8 ],
						"size": [ 3, 16, 16 ]
					},
					"minecraft:selection_box": {
						"origin": [ -8, 0, -8 ],
						"size": [ 3, 16, 16 ]
					}
				}
			},
			{
				"condition": "q.block_state('solariscore:open_bit') && q.block_state('solariscore:door_hinge_bit')",
				"components": {
					"minecraft:collision_box": {
						"origin": [ 5, 0, -8 ],
						"size": [ 3, 16, 16 ]
					},
					"minecraft:selection_box": {
						"origin": [ 5, 0, -8 ],
						"size": [ 3, 16, 16 ]
					}
				}
			},
			{
				"condition": "q.block_state('minecraft:multi_block_part') == 1",
				"components": {
					"minecraft:material_instances": {
						"*": {
							"texture": "ajisa_door_upper",
							"render_method": "blend"
						}
					}
				}
			}
		]
	}
}