{
    "format_version": "1.26.0",
    "minecraft:entity": {
        "description": {
            "identifier": "dbe:dinosaur",
            "is_spawnable": true,
            "is_summonable": true
        },

        "component_groups": {
            "dbe:dinosaur_brown": {
                "minecraft:variant": {
                    "value": 0
                }
            },
            "dbe:dinosaur_gray": {
                "minecraft:variant": {
                    "value": 1
                }
            },
            "dbe:dinosaur_green": {
                "minecraft:variant": {
                    "value": 2
                }
            },
            "dbe:dinosaur_orange": {
                "minecraft:variant": {
                    "value": 3
                }
            },
            "dbe:dinosaur_purple": {
                "minecraft:variant": {
                    "value": 4
                }
            },
            "dbe:dinosaur_yellow": {
                "minecraft:variant": {
                    "value": 5
                }
            },
            "dbe:dinosaur_alien_blue": {
                "minecraft:variant": {
                    "value": 6
                }
            },
            "dbe:dinosaur_alien_red": {
                "minecraft:variant": {
                    "value": 7
                }
            },
            "dbe:dinosaur_wild": {
                "minecraft:behavior.nearest_attackable_target": {
                    "priority": 4,
                    "within_radius": 16,
                    "entity_types": [
                        {
                            "max_dist": 16,
                            "filters": {
                                "all_of": [
                                    {
                                        "any_of": [
                                            {
                                                "test": "is_family",
                                                "subject": "other",
                                                "value": "animal"
                                            },
                                            {
                                                "test": "is_family",
                                                "subject": "other",
                                                "value": "player"
                                            }
                                        ]
                                    },
                                    {
                                        "test": "is_family",
                                        "subject": "other",
                                        "operator": "!=",
                                        "value": "dinosaur"
                                    },
                                    {
                                        "test": "is_sneaking",
                                        "subject": "other",
                                        "value": false
                                    }
                                ]
                            }
                        }
                    ]
                },
                "minecraft:experience_reward": {
                    "on_death": "q.last_hit_by_player ? Math.Random(1, 3) : 0"
                },
                "minecraft:tameable": {
                    "probability": 0.1,
                    "tame_items": [
                        "chicken",
                        "cooked_chicken",
                        "beef",
                        "cooked_beef",
                        "muttonRaw",
                        "muttonCooked",
                        "porkchop",
                        "cooked_porkchop",
                        "rabbit",
                        "cooked_rabbit",
                        "rotten_flesh"
                    ],
                    "tame_event": {
                        "event": "dbe:on_tame"
                    }
                }
            },
            "dbe:dinosaur_tamed": {
                "minecraft:behavior.owner_hurt_by_target": {
                    "priority": 1
                },
                "minecraft:behavior.owner_hurt_target": {
                    "priority": 2
                },
                "minecraft:behavior.stay_while_sitting": {
                    "priority": 3
                },
                "minecraft:behavior.tempt": {
                    "priority": 5,
                    "speed_multiplier": 1.2,
                    "items": [
                        "chicken",
                        "cooked_chicken",
                        "beef",
                        "cooked_beef",
                        "muttonRaw",
                        "muttonCooked",
                        "porkchop",
                        "cooked_porkchop",
                        "rabbit",
                        "cooked_rabbit",
                        "rotten_flesh"
                    ]
                },
                "minecraft:behavior.follow_owner": {
                    "priority": 6,
                    "speed_multiplier": 1,
                    "start_distance": 10,
                    "stop_distance": 2
                },
                "minecraft:equippable": {
                    "slots": [
                        {
                            "slot": 0,
                            "item": "saddle",
                            "accepted_items": [ "saddle" ],
                            "on_equip": {
                                "event": "dbe:dinosaur_saddled"
                            },
                            "on_unequip": {
                                "event": "dbe:dinosaur_unsaddled"
                            }
                        }
                    ]
                },
                "minecraft:interact": {
                    "interactions": [
                        {
                            "equip_item_slot": "0",
                            "interact_text": "action.interact.equip",
                            "play_sounds": "armor.equip_generic",
                            "on_interact": {
                                "filters": {
                                    "all_of": [
                                        { "test": "has_equipment", "domain": "inventory", "operator": "not", "value": "saddle" },
                                        { "test": "has_equipment", "subject": "other", "domain": "hand", "value": "saddle" },
                                        { "test": "is_sneak_held", "subject": "other", "value": false }
                                    ]
                                }
                            }
                        },
                        {
                            "drop_item_slot": "0",
                            "drop_item_y_offset": 1.1,
                            "hurt_item": 1,
                            "interact_text": "action.interact.removesaddle",
                            "play_sounds": "unsaddle",
                            "vibration": "shear",
                            "on_interact": {
                                "filters": {
                                    "all_of": [
                                        { "test": "rider_count", "operator": "equals", "value": 0 },
                                        { "test": "has_equipment", "domain": "inventory", "value": "saddle" },
                                        { "test": "has_equipment", "subject": "other", "domain": "hand", "value": "shears" },
                                        { "test": "is_sneak_held", "subject": "other", "value": false }
                                    ]
                                }
                            }
                        },
                        {
                            "interact_text": "action.interact.attachchest",
                            "play_sounds": "armor.equip_generic",
                            "use_item": true,
                            "on_interact": {
                                "filters": {
                                    "all_of": [
                                        { "test": "has_component", "operator": "not", "value": "minecraft:is_chested" },
                                        { "test": "is_sneaking", "subject": "other", "value": false },
                                        { "test": "has_equipment", "domain": "hand", "subject": "other", "value": "chest" }
                                    ]
                                },
                                "event": "dbe:on_chest"
                            }
                        }
                    ]
                },
                "minecraft:inventory": {
                    "inventory_size": 18,
                    "restrict_to_owner": false,
                    "container_type": "horse"
                },
                "minecraft:sittable": {
                    "sit_event": {
                        "event": "dbe:start_sitting"
                    },
                    "stand_event": {
                        "event": "dbe:stop_sitting"
                    }
                },
                "minecraft:is_tamed": { }
            },
            "dbe:dinosaur_chested": {
                "minecraft:is_chested": { }
            },
            "dbe:dinosaur_saddled": {
                "minecraft:behavior.player_ride_tamed": { },
                "minecraft:dash_action": { },
                "minecraft:input_ground_controlled": { },
                "minecraft:is_saddled": { }
            },
            "dbe:dinosaur_rideable": {
                "minecraft:rideable": {
                    "crouching_skip_interact": true,
                    "interact_text": "action.interact.ride.dinosaur",
                    "seat_count": 2,
                    "family_types": [
                        "player"
                    ],
                    "seats": [
                        {
                            "position": [ 0, 2.2, 0.375 ],
                            "min_rider_count": 0,
                            "max_rider_count": 2
                        },
                        {
                            "position": [ 0, 2.1, -0.25 ],
                            "min_rider_count": 1,
                            "max_rider_count": 2
                        }
                    ]
                }
            },
            "dbe:dinosaur_standing": {
                "minecraft:collision_box": {
                    "width": 2.2,
                    "height": 3
                },
                "minecraft:movement": {
                    "value": 0.22
                },
                "minecraft:pushable_by_block": { },
                "minecraft:pushable_by_entity": { }
            },
            "dbe:dinosaur_sitting": {
                "minecraft:collision_box": {
                    "width": 2.2,
                    "height": 2.8
                },
                "minecraft:movement": {
                    "value": 0
                }
            }
        },

        "components": {
            "minecraft:attack": {
                "damage": 10
            },
            "minecraft:behavior.float": {
                "priority": 0
            },
            "minecraft:behavior.hurt_by_target": {
                "priority": 3
            },
            "minecraft:behavior.delayed_attack": {
                "priority": 4,
                "attack_duration": 1.5,
                "hit_delay_pct": 0.4
            },
            "minecraft:behavior.random_stroll": {
                "priority": 8
            },
            "minecraft:breathable": {
                "total_supply": 15,
                "suffocate_time": 0
            },
            "minecraft:custom_hit_test": {
                "hitboxes": [
                    {
                        "width": 2,
                        "height": 3,
                        "pivot": [ 0, 1.5, 1 ]
                    },
                    {
                        "width": 2,
                        "height": 3,
                        "pivot": [ 0, 1.5, -1 ]
                    }
                ]
            },

            "minecraft:damage_sensor": {
                "triggers": [
                    {
                        "cause": "fall",
                        "deals_damage": "no"
                    },
                    {
                        "deals_damage": "no",
                        "on_damage": {
                            "filters": [
                                {
                                    "test": "has_component",
                                    "value": "minecraft:is_tamed"
                                },
                                {
                                    "any_of": [
                                        {
                                            "test": "is_family",
                                            "subject": "other",
                                            "value": "player"
                                        },
                                        {
                                            "test": "is_family",
                                            "subject": "other",
                                            "value": "quest_mob"
                                        }
                                    ]
                                }
                            ]
                        }
                    }
                ]
            },
            "minecraft:despawn": {
                "despawn_from_distance": { }
            },
            "minecraft:health": {
                "value": 70,
                "max": 70
            },
            "minecraft:hurt_on_condition": {
                "damage_conditions": [
                    {
                        "filters": {
                            "test": "in_lava",
                            "subject": "self"
                        },
                        "cause": "lava",
                        "damage_per_tick": 4
                    }
                ]
            },
            "minecraft:loot": {
                "table": "loot_tables/entities/dinosaur.json"
            },
            "minecraft:movement": {
                "value": 0.22
            },
            "minecraft:navigation.walk": {
                "avoid_damage_blocks": true,
                "can_path_over_water": true
            },
            "minecraft:scale": {
                "value": 1.5
            },
            "minecraft:type_family": {
                "family": [
                    "mob",
                    "dinosaur"
                ]
            },
            "minecraft:variable_max_auto_step": {
                "base_value": 1,
                "controlled_value": 1,
                "jump_prevented_value": 1
            },
            "minecraft:can_climb": { },
            "minecraft:conditional_bandwidth_optimization": { },
            "minecraft:is_hidden_when_invisible": { },
            "minecraft:jump.static": { },
            "minecraft:movement.basic": { },
            "minecraft:nameable": { },
            "minecraft:physics": { }
        },

        "events": {
            "minecraft:entity_spawned": {
                "sequence": [
                    {
                        "add": {
                            "component_groups": [
                                "dbe:dinosaur_standing",
                                "dbe:dinosaur_wild"
                            ]
                        }
                    },
                    {
                        "filters": {
                            "test": "has_biome_tag",
                            "value": "diablo_desert"
                        },
                        "randomize": [
                            {
                                "add": {
                                    "component_groups": [
                                        "dbe:dinosaur_brown"
                                    ]
                                }
                            },
                            {
                                "add": {
                                    "component_groups": [
                                        "dbe:dinosaur_gray"
                                    ]
                                }
                            }
                        ]
                    },
                    {
                        "filters": {
                            "test": "has_biome_tag",
                            "value": "dirtstone"
                        },
                        "randomize": [
                            {
                                "add": {
                                    "component_groups": [
                                        "dbe:dinosaur_green"
                                    ]
                                }
                            },
                            {
                                "add": {
                                    "component_groups": [
                                        "dbe:dinosaur_orange"
                                    ]
                                }
                            },
                            {
                                "add": {
                                    "component_groups": [
                                        "dbe:dinosaur_purple"
                                    ]
                                }
                            },
                            {
                                "add": {
                                    "component_groups": [
                                        "dbe:dinosaur_yellow"
                                    ]
                                }
                            }
                        ]
                    },
                    {
                        "filters": {
                            "test": "has_biome_tag",
                            "value": "namek"
                        },
                        "randomize": [
                            {
                                "add": {
                                    "component_groups": [
                                        "dbe:dinosaur_alien_blue"
                                    ]
                                }
                            },
                            {
                                "add": {
                                    "component_groups": [
                                        "dbe:dinosaur_alien_red"
                                    ]
                                }
                            }
                        ]
                    }
                ]
            },
            "dbe:on_chest": {
                "add": {
                    "component_groups": [
                        "dbe:dinosaur_chested"
                    ]
                }
            },
            "dbe:on_tame": {
                "remove": {
                    "component_groups": [
                        "dbe:dinosaur_wild"
                    ]
                },
                "add": {
                    "component_groups": [
                        "dbe:dinosaur_rideable",
                        "dbe:dinosaur_tamed"
                    ]
                }
            },
            "dbe:dinosaur_saddled": {
                "add": {
                    "component_groups": [
                        "dbe:dinosaur_saddled"
                    ]
                }
            },
            "dbe:dinosaur_unsaddled": {
                "remove": {
                    "component_groups": [
                        "dbe:dinosaur_saddled"
                    ]
                }
            },
            "dbe:start_sitting": {
                "remove": {
                    "component_groups": [
                        "dbe:dinosaur_rideable",
                        "dbe:dinosaur_standing"
                    ]
                },
                "add": {
                    "component_groups": [
                        "dbe:dinosaur_sitting"
                    ]
                }
            },
            "dbe:stop_sitting": {
                "remove": {
                    "component_groups": [
                        "dbe:dinosaur_sitting"
                    ]
                },
                "add": {
                    "component_groups": [
                        "dbe:dinosaur_rideable",
                        "dbe:dinosaur_standing"
                    ]
                }
            }
        }
    }
}