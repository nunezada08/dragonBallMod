{
    "format_version": "1.21.60",
    "minecraft:entity": {
        "description": {
            "identifier": "dbe:pterosaur",
            "is_spawnable": true,
            "is_summonable": true
        },

        "component_groups": {
            "dbe:pterosaur_blue": {
                "minecraft:variant": {
                    "value": 0
                }
            },
            "dbe:pterosaur_green": {
                "minecraft:variant": {
                    "value": 1
                }
            },
            "dbe:pterosaur_purple": {
                "minecraft:variant": {
                    "value": 3
                }
            },
            "dbe:pterosaur_red": {
                "minecraft:variant": {
                    "value": 2
                }
            },
            "dbe:pterosaur_wild": {
                "minecraft:behavior.nearest_attackable_target": {
                    "priority": 4,
                    "within_radius": 16,
                    "entity_types": [
                        {
                            "max_dist": 16,
                            "filters": {
                                "all_of": [
                                    {
                                        "any_of": [
                                            {
                                                "test": "is_family",
                                                "subject": "other",
                                                "value": "animal"
                                            },
                                            {
                                                "test": "is_family",
                                                "subject": "other",
                                                "value": "player"
                                            }
                                        ]
                                    },
                                    {
                                        "test": "is_family",
                                        "subject": "other",
                                        "operator": "!=",
                                        "value": "pterosaur"
                                    },
                                    {
                                        "test": "is_sneaking",
                                        "subject": "other",
                                        "value": false
                                    }
                                ]
                            }
                        }
                    ]
                },
                "minecraft:experience_reward": {
                    "on_death": "q.last_hit_by_player ? Math.Random(1, 3) : 0"
                },
                "minecraft:tameable": {
                    "probability": 0.1,
                    "tame_items": [
                        "dbe:cooked_giant_fish",
                        "dbe:giant_fish"
                    ],
                    "tame_event": {
                        "event": "dbe:on_tame"
                    }
                }
            },
            "dbe:pterosaur_tamed": {
                "minecraft:behavior.owner_hurt_by_target": {
                    "priority": 1
                },
                "minecraft:behavior.owner_hurt_target": {
                    "priority": 2
                },
                "minecraft:behavior.stay_while_sitting": {
                    "priority": 3
                },
                "minecraft:behavior.tempt": {
                    "priority": 5,
                    "speed_multiplier": 1.2,
                    "stop_distance": 4,
                    "within_radius": 32,
                    "items": [
                        "dbe:cooked_giant_fish",
                        "dbe:giant_fish"
                    ]
                },
                "minecraft:behavior.follow_owner": {
                    "priority": 6,
                    "start_distance": 48,
                    "stop_distance": 20
                },
                "minecraft:equippable": {
                    "slots": [
                        {
                            "slot": 0,
                            "item": "saddle",
                            "accepted_items": [ "saddle" ],
                            "on_equip": {
                                "event": "dbe:pterosaur_saddled"
                            },
                            "on_unequip": {
                                "event": "dbe:pterosaur_unsaddled"
                            }
                        }
                    ]
                },
                "minecraft:interact": {
                    "interactions": [
                        {
                            "equip_item_slot": "0",
                            "interact_text": "action.interact.equip",
                            "play_sounds": "armor.equip_generic",
                            "on_interact": {
                                "filters": {
                                    "all_of": [
                                        { "test": "has_equipment", "domain": "inventory", "operator": "not", "value": "saddle" },
                                        { "test": "has_equipment", "subject": "other", "domain": "hand", "value": "saddle" },
                                        { "test": "is_sneak_held", "subject": "other", "value": false }
                                    ]
                                }
                            }
                        },
                        {
                            "drop_item_slot": "0",
                            "drop_item_y_offset": 1.1,
                            "hurt_item": 1,
                            "interact_text": "action.interact.removesaddle",
                            "play_sounds": "unsaddle",
                            "vibration": "shear",
                            "on_interact": {
                                "filters": {
                                    "all_of": [
                                        { "test": "rider_count", "operator": "equals", "value": 0 },
                                        { "test": "has_equipment", "domain": "inventory", "value": "saddle" },
                                        { "test": "has_equipment", "subject": "other", "domain": "hand", "value": "shears" },
                                        { "test": "is_sneak_held", "subject": "other", "value": false }
                                    ]
                                }
                            }
                        },
                        {
                            "interact_text": "action.interact.attachchest",
                            "play_sounds": "armor.equip_generic",
                            "use_item": true,
                            "on_interact": {
                                "filters": {
                                    "all_of": [
                                        { "test": "has_component", "operator": "not", "value": "minecraft:is_chested" },
                                        { "test": "is_sneaking", "subject": "other", "value": false },
                                        { "test": "has_equipment", "domain": "hand", "subject": "other", "value": "chest" }
                                    ]
                                },
                                "event": "dbe:on_chest"
                            }
                        }
                    ]
                },
                "minecraft:inventory": {
                    "inventory_size": 18,
                    "restrict_to_owner": true,
                    "container_type": "horse"
                },
                "minecraft:is_tamed": { }
            },
            "dbe:pterosaur_chested": {
                "minecraft:is_chested": { }
            },
            "dbe:pterosaur_saddled": {
                "minecraft:behavior.player_ride_tamed": { },
                "minecraft:dash_action": { },
                "minecraft:free_camera_controlled": { },
                "minecraft:is_saddled": { }
            },
            "dbe:pterosaur_rideable": {
                "minecraft:rideable": {
                    "crouching_skip_interact": true,
                    "interact_text": "action.interact.ride.pterosaur",
                    "on_rider_enter_event": "dbe:switch_to_fly",
                    "family_types": [
                        "player"
                    ],
                    "seats": {
                        "position": [ 0, 1.7, 0.4 ],
                        "third_person_camera_radius": 12
                    }
                }
            },
            "dbe:fly_mode": {
                "minecraft:behavior.random_hover": {
                    "priority": 7,
                    "xz_dist": 64,
                    "y_dist": 32,
                    "y_offset": -1,
                    "interval": 1,
                    "hover_height": [ 16, 48 ]
                },
                "minecraft:movement.hover": {
                    "max_turn": 15
                },
                "minecraft:navigation.hover": {
                    "avoid_damage_blocks": true,
                    "can_path_from_air": true,
                    "can_path_over_water": true
                },
                "minecraft:physics": {
                    "has_gravity": false
                },
                "minecraft:can_fly": { }
            },
            "dbe:walk_mode": {
                "minecraft:behavior.random_stroll": {
                    "priority": 7
                },
                "minecraft:movement.basic": {
                    "max_turn": 15
                },
                "minecraft:navigation.walk": {
                    "avoid_damage_blocks": true,
                    "can_path_over_water": true
                },
                "minecraft:can_climb": { },
                "minecraft:physics": { }
            }
        },

        "components": {
            "minecraft:attack": {
                "damage": 6
            },
            "minecraft:balloonable": {
                "mass": 0.5
            },
            "minecraft:behavior.float": {
                "priority": 0
            },
            "minecraft:breathable": {
                "total_supply": 15,
                "suffocate_time": 0
            },
            "minecraft:collision_box": {
                "width": 2.2,
                "height": 1.7
            },
            "minecraft:conditional_bandwidth_optimization": {
                "default_values": {
                    "max_dropped_ticks": 0
                }
            },
            "minecraft:damage_sensor": {
                "triggers": [
                    {
                        "cause": "fall",
                        "deals_damage": "no"
                    },
                    {
                        "deals_damage": "no",
                        "on_damage": {
                            "filters": [
                                {
                                    "test": "has_component",
                                    "value": "minecraft:is_tamed"
                                },
                                {
                                    "any_of": [
                                        {
                                            "test": "is_family",
                                            "subject": "other",
                                            "value": "player"
                                        },
                                        {
                                            "test": "is_family",
                                            "subject": "other",
                                            "value": "quest_mob"
                                        }
                                    ]
                                }
                            ]
                        }
                    }
                ]
            },
            "minecraft:despawn": {
                "despawn_from_distance": { }
            },
            "minecraft:environment_sensor": {
                "triggers": [
                    {
                        "event": "dbe:switch_to_fly",
                        "filters": {
                            "all_of": [
                                {
                                    "test": "random_chance",
                                    "value": 100
                                },
                                {
                                    "test": "has_component",
                                    "value": "minecraft:movement.basic"
                                }
                            ]
                        }
                    },
                    {
                        "event": "dbe:switch_to_walk",
                        "filters": {
                            "all_of": [
                                {
                                    "test": "rider_count",
                                    "value": 0
                                },
                                {
                                    "test": "random_chance",
                                    "value": 100
                                },
                                {
                                    "test": "has_component",
                                    "value": "minecraft:movement.hover"
                                }
                            ]
                        }
                    }
                ]
            },
            "minecraft:experience_reward": {
                "on_death": "query.last_hit_by_player ? 5 : 0"
            },
            "minecraft:flying_speed": {
                "value": 0.25
            },
            "minecraft:follow_range": {
                "value": 64,
                "max": 64
            },
            "minecraft:game_event_movement_tracking": {
                "emit_flap": true
            },
            "minecraft:health": {
                "value": 40,
                "max": 40
            },
            "minecraft:hurt_on_condition": {
                "damage_conditions": [
                    {
                        "filters": {
                            "test": "in_lava"
                        },
                        "cause": "lava",
                        "damage_per_tick": 4
                    }
                ]
            },
            "minecraft:loot": {
                "table": "loot_tables/entities/pterosaur.json"
            },
            "minecraft:movement": {
                "value": 0.1
            },
            "minecraft:physics": {
                "has_gravity": false
            },
            "minecraft:type_family": {
                "family": [
                    "pterosaur",
                    "mob"
                ]
            },
            "minecraft:variable_max_auto_step": {
                "base_value": 1,
                "controlled_value": 1,
                "jump_prevented_value": 1
            },
            "minecraft:is_hidden_when_invisible": { },
            "minecraft:jump.static": { },
            "minecraft:nameable": { },
            "minecraft:pushable_by_block": { },
            "minecraft:pushable_by_entity": { }
        },

        "events": {
            "minecraft:entity_spawned": {
                "sequence": [
                    {
                        "add": {
                            "component_groups": [
                                "dbe:pterosaur_wild",
                                "dbe:walk_mode"
                            ]
                        }
                    },
                    {
                        "filters": {
                            "test": "has_biome_tag",
                            "value": "diablo_desert"
                        },
                        "randomize": [
                            {
                                "add": {
                                    "component_groups": [
                                        "dbe:pterosaur_green"
                                    ]
                                }
                            },
                            {
                                "add": {
                                    "component_groups": [
                                        "dbe:pterosaur_red"
                                    ]
                                }
                            }
                        ]
                    },
                    {
                        "filters": {
                            "test": "has_biome_tag",
                            "value": "dirtstone"
                        },
                        "randomize": [
                            {
                                "add": {
                                    "component_groups": [
                                        "dbe:pterosaur_blue"
                                    ]
                                }
                            },
                            {
                                "add": {
                                    "component_groups": [
                                        "dbe:pterosaur_purple"
                                    ]
                                }
                            }
                        ]
                    }
                ]
            },
            "dbe:on_chest": {
                "add": {
                    "component_groups": [
                        "dbe:pterosaur_chested"
                    ]
                }
            },
            "dbe:on_tame": {
                "remove": {
                    "component_groups": [
                        "dbe:pterosaur_wild"
                    ]
                },
                "add": {
                    "component_groups": [
                        "dbe:pterosaur_rideable",
                        "dbe:pterosaur_tamed"
                    ]
                }
            },
            "dbe:pterosaur_saddled": {
                "add": {
                    "component_groups": [
                        "dbe:pterosaur_saddled"
                    ]
                }
            },
            "dbe:pterosaur_unsaddled": {
                "remove": {
                    "component_groups": [
                        "dbe:pterosaur_saddled"
                    ]
                }
            },
            "dbe:switch_to_fly": {
                "remove": {
                    "component_groups": [
                        "dbe:walk_mode"
                    ]
                },
                "add": {
                    "component_groups": [
                        "dbe:fly_mode"
                    ]
                }
            },
            "dbe:switch_to_walk": {
                "remove": {
                    "component_groups": [
                        "dbe:fly_mode"
                    ]
                },
                "add": {
                    "component_groups": [
                        "dbe:walk_mode"
                    ]
                }
            }
        }
    }
}
