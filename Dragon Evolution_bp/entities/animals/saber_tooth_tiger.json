{
    "format_version": "1.26.0",
    "minecraft:entity": {
        "description": {
            "identifier": "dbe:saber_tooth_tiger",
            "is_spawnable": true,
            "is_summonable": true
        },

        "component_groups": {
            "dbe:saber_tooth_tiger_black": {
                "minecraft:variant": {
                    "value": 0
                }
            },
            "dbe:saber_tooth_tiger_orange": {
                "minecraft:variant": {
                    "value": 1
                }
            },
            "dbe:saber_tooth_tiger_white": {
                "minecraft:variant": {
                    "value": 2
                }
            },
            "dbe:saber_tooth_tiger_wild": {
                "minecraft:behavior.nearest_attackable_target": {
                    "priority": 4,
                    "within_radius": 16,
                    "attack_interval": {
                        "max": 16
                    },
                    "entity_types": [
                        {
                            "filters": {
                                "any_of": [
                                    {
                                        "test": "is_family",
                                        "subject": "other",
                                        "value": "donkey"
                                    },
                                    {
                                        "test": "is_family",
                                        "subject": "other",
                                        "value": "mule"
                                    },
                                    {
                                        "test": "is_family",
                                        "subject": "other",
                                        "value": "pig"
                                    }
                                ]
                            },
                            "max_dist": 16
                        },
                        {
                            "filters": {
                                "all_of": [
                                    {
                                        "test": "is_family",
                                        "subject": "other",
                                        "value": "player"
                                    },
                                    {
                                        "test": "is_sneaking",
                                        "subject": "other",
                                        "value": false
                                    }
                                ]
                            },
                            "max_dist": 8,
                            "must_see": true
                        }
                    ]
                },
                "minecraft:tameable": {
                    "probability": 0.33,
                    "tame_items": [
                        "porkchop",
                        "cooked_porkchop"
                    ],
                    "tame_event": {
                        "event": "dbe:on_tame"
                    }
                }
            },
            "dbe:saber_tooth_tiger_tamed": {
                "minecraft:behavior.owner_hurt_by_target": {
                    "priority": 1
                },
                "minecraft:behavior.owner_hurt_target": {
                    "priority": 2
                },
                "minecraft:behavior.stay_while_sitting": {
                    "priority": 3
                },
                "minecraft:behavior.tempt": {
                    "priority": 5,
                    "speed_multiplier": 1.2,
                    "items": [
                        {
                            "tags": "q.any_tag('minecraft:is_meat')"
                        }
                    ]
                },
                "minecraft:behavior.follow_owner": {
                    "priority": 6,
                    "speed_multiplier": 1.0,
                    "start_distance": 10,
                    "stop_distance": 2
                },
                "minecraft:is_tamed": { },
                "minecraft:sittable": { }
            }
        },

        "components": {
            "minecraft:attack": {
                "damage": 4
            },
            "minecraft:behavior.float": {
                "priority": 0
            },
            "minecraft:behavior.hurt_by_target": {
                "priority": 4
            },
            "minecraft:behavior.melee_box_attack": {
                "priority": 4,
                "cooldown_time": 1.5,
                "speed_multiplier": 1.4
            },
            "minecraft:behavior.look_at_player": {
                "priority": 6,
                "look_distance": 5,
                "probability": 0.02
            },
            "minecraft:behavior.nap": {
                "priority": 8,
                "cooldown_min": 2,
                "cooldown_max": 7,
                "mob_detect_dist": 4,
                "mob_detect_height": 2,
                "can_nap_filters": {
                    "all_of": [
                        { "test": "in_water", "value": false },
                        { "test": "on_ground" }
                    ]
                },
                "wake_mob_exceptions": {
                    "any_of": [
                        { "test": "is_family", "subject": "other", "value": "saber_tooth_tiger" },
                        { "test": "is_sneaking", "subject": "other" }
                    ]
                }
            },
            "minecraft:behavior.random_stroll": {
                "priority": 8,
                "speed_multiplier": 1
            },
            "minecraft:breathable": {
                "total_supply": 15,
                "suffocate_time": 0
            },
            "minecraft:collision_box": {
                "width": 1.2,
                "height": 1.9
            },

            "minecraft:damage_sensor": {
                "triggers": [
                    {
                        "cause": "fall",
                        "deals_damage": "no"
                    },
                    {
                        "deals_damage": "no",
                        "on_damage": {
                            "filters": [
                                {
                                    "test": "has_component",
                                    "value": "minecraft:is_tamed"
                                },
                                {
                                    "any_of": [
                                        {
                                            "test": "is_family",
                                            "subject": "other",
                                            "value": "player"
                                        },
                                        {
                                            "test": "is_family",
                                            "subject": "other",
                                            "value": "quest_mob"
                                        }
                                    ]
                                }
                            ]
                        }
                    }
                ]
            },
            "minecraft:despawn": {
                "despawn_from_distance": { }
            },
            "minecraft:health": {
                "value": 40,
                "max": 40
            },
            "minecraft:hurt_on_condition": {
                "damage_conditions": [
                    {
                        "filters": {
                            "test": "in_lava"
                        },
                        "cause": "lava",
                        "damage_per_tick": 4
                    }
                ]
            },
            "minecraft:loot": {
                "table": "loot_tables/entities/saber_tooth_tiger.json"
            },
            "minecraft:movement": {
                "value": 0.28
            },
            "minecraft:navigation.walk": {
                "avoid_damage_blocks": true,
                "can_path_over_water": true
            },
            "minecraft:type_family": {
                "family": [
                    "mob",
                    "saber_tooth_tiger"
                ]
            },
            "minecraft:can_climb": { },
            "minecraft:conditional_bandwidth_optimization": { },
            "minecraft:is_hidden_when_invisible": { },
            "minecraft:jump.static": { },
            "minecraft:movement.basic": { },
            "minecraft:nameable": { },
            "minecraft:physics": { },
            "minecraft:pushable_by_block": { },
            "minecraft:pushable_by_entity": { }
        },

        "events": {
            "minecraft:entity_spawned": {
                "sequence": [
                    {
                        "add": {
                            "component_groups": [ "dbe:saber_tooth_tiger_wild" ]
                        }
                    },
                    {
                        "filters": {
                            "test": "has_biome_tag",
                            "value": "dirtstone"
                        },
                        "add": {
                            "component_groups": [
                                "dbe:saber_tooth_tiger_orange"
                            ]
                        }
                    },
                    {
                        "filters": {
                            "test": "has_biome_tag",
                            "value": "diablo_desert"
                        },
                        "randomize": [
                            {
                                "add": {
                                    "component_groups": [
                                        "dbe:saber_tooth_tiger_white"
                                    ]
                                }
                            },
                            {
                                "add": {
                                    "component_groups": [
                                        "dbe:saber_tooth_tiger_black"
                                    ]
                                }
                            }
                        ]
                    }
                ]
            },
            "dbe:on_tame": {
                "remove": {
                    "component_groups": [ "dbe:saber_tooth_tiger_wild" ]
                },
                "add": {
                    "component_groups": [ "dbe:saber_tooth_tiger_tamed" ]
                }
            }
        }
    }
}