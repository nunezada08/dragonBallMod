{
    "format_version": "1.26.0",
    "minecraft:entity": {
        "description": {
            "identifier": "dbe:merchant",
            "is_spawnable": false,
            "is_summonable": true,
            "properties": {
                "dbe:has_backpack": {
                    "type": "bool",
                    "default": false,
                    "client_sync": true
                },
                "dbe:has_glasses": {
                    "type": "bool",
                    "default": false,
                    "client_sync": true
                },
                "dbe:skin": {
                    "type": "int",
                    "range": [ 0, 2 ],
                    "default": 0,
                    "client_sync": true
                }
            }
        },

        "component_groups": {
            "dbe:despawn": {
                "minecraft:instant_despawn": { }
            }
        },

        "components": {
            "minecraft:type_family": {
                "family": [ "npc" ]
            },
            "minecraft:health": {
                "value": 1,
                "max": 1,
                "min": 1
            },
            "minecraft:collision_box": {
                "width": 0.6,
                "height": 1.8
            },
            "minecraft:knockback_resistance": {
                "value": 1
            },
            "minecraft:damage_sensor": {
                "triggers": {
                    "deals_damage": "no"
                }
            },
            "minecraft:behavior.look_at_player": {
                "priority": 0,
                "look_distance": 10
            },
            "minecraft:nameable": {
                "always_show": true
            },
            "minecraft:despawn": {
                "despawn_from_distance": { }
            },
            "minecraft:conditional_bandwidth_optimization": { },
            "minecraft:fire_immune": { },
            "minecraft:physics": { }
        },

        "events": {
            "minecraft:entity_spawned": {
                "set_property": {
                    "dbe:has_backpack": "math.random_integer(0, 1) ? true : false",
                    "dbe:has_glasses": "math.random_integer(0, 1) ? true : false",
                    "dbe:skin": "math.random_integer(0, 2)"
                }
            },
            "dbe:despawn": {
                "add": {
                    "component_groups": [ "dbe:despawn" ]
                }
            }
        }
    }
}